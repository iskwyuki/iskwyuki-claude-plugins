{
  "description": "iskwyuki-claude-plugins: セッション開始時のプラグイン更新チェック",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/check-plugin-updates.sh",
            "timeout": 90,
            "statusMessage": "プラグインの更新を確認中..."
          }
        ]
      }
    ]
  }
}
